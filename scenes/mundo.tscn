theme_override_colors/font_outline_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "¡ERES EL OCTO-CHEF!, un pulpo talentoso en la cocina. Tu misión es preparar los pedidos
 del ticket antes de que se acabe el tiempo. ¡Usa tus tentáculos para multitarrear!
"
horizontal_alignment = 1

[node name="TituloContexto" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1672747567]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(1, 1, 1, 0)
theme_override_colors/font_outline_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "FUNDAMENTOS:
"
horizontal_alignment = 1

[node name="TextoContexto" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1141654782]
layout_mode = 2
theme_override_font_sizes/font_size = 15
text = "• Progreso: Llena cada barra al 100% para completar la estación.
• El Plato: Debes completar todas las estaciones del ticket para servirlo.
• ¡ERROR!: Usar una estación incorrecta o ya terminada te quitará tiempo.
"

[node name="TituloContexto2" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1928599920]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(1, 1, 1, 0)
theme_override_colors/font_outline_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "GESTIÓN DE TENTÁCULOS (EL CAOS)
"
horizontal_alignment = 1

[node name="TextoContexto2" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=91217687]
layout_mode = 2
theme_override_font_sizes/font_size = 15
text = "• Puedes usar varias estaciones a la vez, pero mientras más manos
   uses, más lento cocinarás. ¡Equilibra la velocidad con el caos!
"

[node name="TituloContexto3" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=250480958]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(1, 1, 1, 0)
theme_override_colors/font_outline_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "LAS 4 ESTACIONES:
"
horizontal_alignment = 1

[node name="TextoContexto3" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1310405690]
layout_mode = 2
theme_override_font_sizes/font_size = 15
text = "• 🔥 Sartenes: Muy rápidas, pero se enfrían rápido si las sueltas.
• 🔪 Picadoras: Velocidad promedio y el progreso no baja.
• 🍲 Ollas: Cocción lenta y el progreso baja muy poco a poco.
• 🍽️ Emplatar: Velocidad y enfriamiento equilibrados.
"

[node name="TituloContexto4" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1812348322]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
