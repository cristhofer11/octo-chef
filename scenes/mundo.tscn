theme_override_colors/font_outline_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 15
text = "MODO EXPERTO (POST-META):
"
horizontal_alignment = 1

[node name="TextoContexto4" type="Label" parent="CapaInstrucciones/PanelContexto/MarginContainer/VBoxContainer" unique_id=1015597101]
layout_mode = 2
theme_override_font_sizes/font_size = 15
text = "• Dificultad: Al superar el mínimo de platos, los pedidos pedirán más estaciones.
• Bonus: Cada plato extra entregado te dará Segundos de Bonus aleatorios para 
	   romper tu récord."

